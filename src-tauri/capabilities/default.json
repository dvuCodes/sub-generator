{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for SubGen",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "subgen-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "file:///*" }]
    },
    "dialog:allow-open"
  ]
}
